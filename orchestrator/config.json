{
  "name": "LifeAtlas Orchestrator",
  "version": "1.6.1",
  "slug": "lifeatlas_orchestrator",
  "description": "The central orchestrator for the LifeAtlas project, running as a Home Assistant add-on.",
  "url": "https://github.com/Niki1988/LifeAtlas",
  "arch": ["amd64", "aarch64"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "image": "ghcr.io/niki1988/lifeatlas-orchestrator",
  "panel_icon": "mdi:brain",
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "Web interface for the Orchestrator"
  },
  "map": ["config:rw"],
  "options": {
    "database_url": "sqlite:////config/lifeatlas.db",
    "google_api_key": null,
    "google_drive_credentials": null
  },
  "schema": {
    "database_url": "str",
    "google_api_key": "password",
    "google_drive_credentials": "password"
  }
}
